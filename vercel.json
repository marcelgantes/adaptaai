{
  "version": 2,
  "public": true,
  "buildCommand": "echo 'Static site - no build needed'",
  "outputDirectory": "client/public",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*\\.(png|jpg|jpeg|gif|svg|ico|css|js|woff|woff2))", "dest": "/$1" },
    { "src": "/app", "dest": "/index.html" },
    { "src": "/app/(.*)", "dest": "/index.html" },
    { "src": "/", "dest": "/landing.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
